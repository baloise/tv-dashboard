{
  "name": "tv-cli",
  "version": "1.1.0",
  "private": true,
  "bin": { "tv": "./tv.js" },
  "main": "tv.js",
  "scripts": {
    "start": "node setup.js",
    "setup": "node setup.js",
    "status": "node tv.js status",
    "sync": "node tv.js sync",
    "skip": "node tv.js skip",
    "reload": "node tv.js reload",
    "unforce": "node tv.js unforce",
    "presets": "node tv.js presets",
    "menu": "node tv.js show menu",
    "depot": "node tv.js show depot",
    "overview": "node tv.js show overview",
    "coffee:on": "node tv.js coffee on",
    "coffee:off": "node tv.js coffee off",
    "build": "pkg tv.js --targets node20-win-x64 --output dist/tv.exe"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.16.1"
  },
  "engines": {
    "node": ">=20"
  },
  "pkg": {
    "assets": ["default-config.json", "config.json"]
  }
}
