{
  "manifest_version": 3,
  "name": "TV Dashboard Rotator",
  "version": "1.0",
  "description": "Rotates browser tabs between dashboard URLs on a schedule.",
  "permissions": [
    "tabs",
    "alarms",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TV Dashboard"
  },
  "icons": {}
}
